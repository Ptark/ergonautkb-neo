#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    /*
     * 52-key layout. Positions in LAYOUT order (matching QMK info.json):
     *
     *  0.. 5  = left  row 0 (top)
     *  6..11  = right row 0
     * 12..17  = left  row 1
     * 18..23  = right row 1
     * 24..29  = left  row 2
     * 30..35  = right row 2
     * 36..37  = left  corner  (cols 2-3)
     * 38..39  = right corner  (cols 2-3)
     * 40..41  = left  inner thumb (cols 4-5)
     * 42..43  = right inner thumb (cols 0-1)
     * 44..45  = left  outer thumb top (cols 4-5)
     * 46..47  = right outer thumb top (cols 0-1)
     * 48..49  = left  outer thumb bot (cols 2-3)
     * 50..51  = right outer thumb bot (cols 2-3)
     */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <6>;
        rows = <10>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)   RC(5,0) RC(5,1) RC(5,2) RC(5,3) RC(5,4) RC(5,5)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)   RC(6,0) RC(6,1) RC(6,2) RC(6,3) RC(6,4) RC(6,5)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)   RC(7,0) RC(7,1) RC(7,2) RC(7,3) RC(7,4) RC(7,5)
            RC(3,2) RC(3,3)                                     RC(8,2) RC(8,3)
            RC(3,4) RC(3,5)                                     RC(8,0) RC(8,1)
            RC(4,4) RC(4,5)                                     RC(9,0) RC(9,1)
            RC(4,2) RC(4,3)                                     RC(9,2) RC(9,3)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        /* col-gpios and row-gpios defined in per-half overlays */
    };
};
